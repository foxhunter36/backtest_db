#  TEST 6: WALK-FORWARD VALIDATION
# ═══════════════════════════════════════════════════════════════════════

def test6_walk_forward(raw_df, sl, tp, st_period, st_mult, ao_fast, ao_slow, use_fr, fr_val):
    print("\n" + "=" * 90)
    print("TEST 6: WALK-FORWARD VALIDATION")
    print("Split: 70% Train / 30% Test")
    print("=" * 90)

    df = calc_supertrend(raw_df, period=st_period, multiplier=st_mult)
    df = calc_ao(df, fast=ao_fast, slow=ao_slow)
    df = df.dropna(subset=["atr", "ao"]).reset_index(drop=True)

    split = int(len(df) * 0.7)
    train = df.iloc[:split].reset_index(drop=True)
    test = df.iloc[split:].reset_index(drop=True)

    print(f"  Train: {len(train)} bars ({len(train)/24:.0f} Tage)")
    print(f"  Test:  {len(test)} bars ({len(test)/24:.0f} Tage)")

    # Optimierte Params auf Train
    r_train = backtest(train, sl_mult=sl, tp_mult=tp,
                       fr_long_max=fr_val, fr_short_min=-fr_val, use_fr=use_fr)

    # Gleiche Params auf Test (Out-of-Sample)
    r_test = backtest(test, sl_mult=sl, tp_mult=tp,
                      fr_long_max=fr_val, fr_short_min=-fr_val, use_fr=use_fr)

    # Full dataset
    r_full = backtest(df, sl_mult=sl, tp_mult=tp,
                      fr_long_max=fr_val, fr_short_min=-fr_val, use_fr=use_fr)

    # Default params auf Test (Vergleich)
    df_default = calc_supertrend(raw_df, period=14, multiplier=2.0)
    df_default = calc_ao(df_default, fast=7, slow=34)
    df_default = df_default.dropna(subset=["atr", "ao"]).reset_index(drop=True)
    test_default = df_default.iloc[split:].reset_index(drop=True)
    r_test_default = backtest(test_default, sl_mult=2.0, tp_mult=3.0)

    print(f"\n  {'Dataset':<20s} | {fmt_result(None)}")
    print(f"  {'Train (70%)':<20s} | {fmt_result(r_train)}")
    print(f"  {'Test (30%) OPTIM':<20s} | {fmt_result(r_test)}")
    print(f"  {'Test (30%) DEFAULT':<20s} | {fmt_result(r_test_default)}")
    print(f"  {'Full Dataset':<20s} | {fmt_result(r_full)}")

    if r_test and r_test_default:
        degradation = (r_test["sharpe"] - r_train["sharpe"]) / r_train["sharpe"] * 100 if r_train["sharpe"] != 0 else 0
        improvement = (r_test["sharpe"] - r_test_default["sharpe"]) / abs(r_test_default["sharpe"]) * 100 if r_test_default["sharpe"] != 0 else 0
        print(f"\n  Train→Test Sharpe Degradation: {degradation:+.1f}%")
        print(f"  Optimiert vs Default auf Test:  {improvement:+.1f}% Sharpe Verbesserung")
        if abs(degradation) > 50:
            print("  ⚠️  WARNUNG: Starke Degradation — mögliches Overfitting!")
        elif abs(degradation) < 20:
            print("  ✅ Stabile Performance — Parameter sind robust.")


