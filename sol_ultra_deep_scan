# ═══════════════════════════════════════════════════════════════════════
#  INDICATORS
# ═══════════════════════════════════════════════════════════════════════

def calc_atr(df, period):
    tr = pd.concat([
        df["high"] - df["low"],
        (df["high"] - df["close"].shift(1)).abs(),
        (df["low"] - df["close"].shift(1)).abs()
    ], axis=1).max(axis=1)
    return tr.ewm(alpha=1.0 / period, min_periods=period, adjust=False).mean()


def calc_supertrend(df, period, multiplier):
    df = df.copy()
    atr = calc_atr(df, period)
    df["atr"] = atr
    hl2 = (df["high"] + df["low"]) / 2.0
    upper = (hl2 + multiplier * atr).values
    lower = (hl2 - multiplier * atr).values
    close = df["close"].values
    n = len(df)

    fu = np.full(n, np.nan)
    fl = np.full(n, np.nan)
    d = np.zeros(n, dtype=int)

    s = period
    if s >= n:
        df["st_direction"] = 0
        df["st_long"] = False
        df["st_short"] = False
        return df

    fu[s] = upper[s]; fl[s] = lower[s]; d[s] = -1

    for i in range(s + 1, n):
        fu[i] = upper[i] if (upper[i] < fu[i-1] or close[i-1] > fu[i-1]) else fu[i-1]
        fl[i] = lower[i] if (lower[i] > fl[i-1] or close[i-1] < fl[i-1]) else fl[i-1]
        if d[i-1] == 1:
            if close[i] < fl[i]: d[i] = -1
            else: d[i] = 1
        else:
            if close[i] > fu[i]: d[i] = 1
            else: d[i] = -1

    df["st_direction"] = d
    ds = pd.Series(d, index=df.index)
    df["st_long"] = (ds == 1) & (ds.shift(1) == -1)
    df["st_short"] = (ds == -1) & (ds.shift(1) == 1)
    return df


def calc_ao(df, fast, slow):
    df = df.copy()
    mid = (df["high"] + df["low"]) / 2.0
    df["ao"] = mid.rolling(fast).mean() - mid.rolling(slow).mean()
    return df


def calc_volume_filter(df, sma_period=20, threshold=1.0):
    df = df.copy()
    df["vol_sma"] = df["volume"].rolling(sma_period).mean()
    df["vol_ok"] = df["volume"] > (df["vol_sma"] * threshold)
    return df


# ═══════════════════════════════════════════════════════════════════════
#  BACKTEST ENGINE
# ═══════════════════════════════════════════════════════════════════════

def backtest(df, sl_mult, tp_mult, fr_long_max=0.0001, fr_short_min=-0.0001,
             use_ao=True, use_fr=True, use_vol=False):
    trades = []
    pos = None

    for i in range(1, len(df)):
        row = df.iloc[i]
        c, h, l = row["close"], row["high"], row["low"]

        if pos:
            if pos["side"] == "long":
                if l <= pos["sl"]:
                    trades.append({"pnl": (pos["sl"] - pos["entry"]) / pos["entry"] * 100,
                                   "exit": "SL", "bars": i - pos["bar"]})
                    pos = None
                elif h >= pos["tp"]:
                    trades.append({"pnl": (pos["tp"] - pos["entry"]) / pos["entry"] * 100,
                                   "exit": "TP", "bars": i - pos["bar"]})
                    pos = None
                elif row["st_short"]:
                    trades.append({"pnl": (c - pos["entry"]) / pos["entry"] * 100,
                                   "exit": "FLIP", "bars": i - pos["bar"]})
                    pos = None
            else:
                if h >= pos["sl"]:
                    trades.append({"pnl": (pos["entry"] - pos["sl"]) / pos["entry"] * 100,
                                   "exit": "SL", "bars": i - pos["bar"]})
                    pos = None
                elif l <= pos["tp"]:
                    trades.append({"pnl": (pos["entry"] - pos["tp"]) / pos["entry"] * 100,
                                   "exit": "TP", "bars": i - pos["bar"]})
                    pos = None
                elif row["st_long"]:
                    trades.append({"pnl": (pos["entry"] - c) / pos["entry"] * 100,
                                   "exit": "FLIP", "bars": i - pos["bar"]})
                    pos = None

        if pos:
            continue

        sig = None
        if row["st_long"]: sig = "long"
        elif row["st_short"]: sig = "short"
        if not sig: continue

        # AO filter
        if use_ao:
            if sig == "long" and row["ao"] <= 0: continue
            if sig == "short" and row["ao"] >= 0: continue

        # FR filter
        if use_fr:
            fr = row.get("funding_rate", np.nan)
            if pd.notna(fr):
                if sig == "long" and fr > fr_long_max: continue
                if sig == "short" and fr < fr_short_min: continue

        # Volume filter
        if use_vol:
            if not row.get("vol_ok", True): continue

        atr = row["atr"]
        if atr <= 0: continue

        if sig == "long":
            pos = {"side": "long", "entry": c,
                   "sl": c - sl_mult * atr, "tp": c + tp_mult * atr, "bar": i}
        else:
            pos = {"side": "short", "entry": c,
                   "sl": c + sl_mult * atr, "tp": c - tp_mult * atr, "bar": i}

    if not trades:
        return None

    pnls = np.array([t["pnl"] - FEE_PCT * 2 for t in trades])
    bars = np.array([t["bars"] for t in trades])
    wins = (pnls > 0).sum()
    total = len(pnls)
    cum = np.cumsum(pnls)
    max_dd = (cum - np.maximum.accumulate(cum)).min()
    sharpe = pnls.mean() / pnls.std() * np.sqrt(total) if pnls.std() > 0 else 0
    gp = pnls[pnls > 0].sum()
    gl = abs(pnls[pnls <= 0].sum())
    pf = gp / gl if gl > 0 else float("inf")

    exits = {}
    for t in trades:
        exits[t["exit"]] = exits.get(t["exit"], 0) + 1

    return {
        "trades": total, "wins": wins, "winrate": wins / total * 100,
        "total_pnl": pnls.sum(), "avg_pnl": pnls.mean(),
        "max_dd": max_dd, "sharpe": sharpe, "pf": pf,
        "avg_bars": bars.mean(), "exits": exits
    }


def fmt_result(r):
    if r is None:
        return "  (keine Trades)"
    return (f"Trades={r['trades']:>4d} WR={r['winrate']:>4.0f}% PnL={r['total_pnl']:>+7.1f}% "
            f"Sharpe={r['sharpe']:>5.2f} PF={r['pf']:>5.2f} MaxDD={r['max_dd']:>6.1f}%")


