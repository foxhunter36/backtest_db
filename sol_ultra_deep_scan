#  TEST 2: SUPERTREND FEINES GRID
# ═══════════════════════════════════════════════════════════════════════

def test2_st_params(raw_df, sl, tp):
    print("\n" + "=" * 90)
    print(f"TEST 2: SUPERTREND FEINES GRID (SL={sl}, TP={tp}, AO 7/34 + FR)")
    print("=" * 90)

    atr_periods = [7, 8, 10, 12, 14, 16, 18, 20, 24, 28]
    st_multipliers = [1.0, 1.2, 1.5, 1.8, 2.0, 2.2, 2.5, 2.8, 3.0, 3.5]

    results = []
    total = len(atr_periods) * len(st_multipliers)
    done = 0

    for period, mult in product(atr_periods, st_multipliers):
        done += 1
        df = calc_supertrend(raw_df, period=period, multiplier=mult)
        df = calc_ao(df, fast=7, slow=34)
        df = df.dropna(subset=["atr", "ao"]).reset_index(drop=True)

        r = backtest(df, sl_mult=sl, tp_mult=tp)
        if r:
            r["period"] = period; r["mult"] = mult
            results.append(r)

        if done % 20 == 0:
            print(f"  Progress: {done}/{total}")

    results.sort(key=lambda x: x["sharpe"], reverse=True)

    print(f"\n{'Per':>4s} {'Mult':>5s} | {'Trades':>6s} {'WR%':>5s} {'PnL%':>8s} "
          f"{'Sharpe':>7s} {'PF':>6s} {'MaxDD':>7s}")
    print("-" * 60)
    for r in results[:20]:
        marker = " <-- LIVE" if r["period"] == 14 and r["mult"] == 2.0 else ""
        marker = " <-- NEW" if r == results[0] else marker
        print(f"{r['period']:>4d} {r['mult']:>5.1f} | {r['trades']:>6d} {r['winrate']:>4.0f}% "
              f"{r['total_pnl']:>+7.1f}% {r['sharpe']:>7.2f} {r['pf']:>5.2f} "
              f"{r['max_dd']:>6.1f}%{marker}")

    best = results[0]
    print(f"\n>>> Best ST: ATR({best['period']}) × {best['mult']} (Sharpe={best['sharpe']:.2f})")
    return best["period"], best["mult"]


# ═══════════════════════════════════════════════════════════════════════
#  TEST 3: AO PERIODEN
# ═══════════════════════════════════════════════════════════════════════

def test3_ao_params(raw_df, sl, tp, st_period, st_mult):
    print("\n" + "=" * 90)
    print(f"TEST 3: AO PERIODEN (ST: ATR{st_period} × {st_mult}, SL={sl}, TP={tp})")
    print("=" * 90)

    ao_fasts = [3, 5, 7, 9, 12, 15]
    ao_slows = [20, 26, 30, 34, 40, 50]

    results = []
    for fast, slow in product(ao_fasts, ao_slows):
        if fast >= slow: continue

        df = calc_supertrend(raw_df, period=st_period, multiplier=st_mult)
        df = calc_ao(df, fast=fast, slow=slow)
        df = df.dropna(subset=["atr", "ao"]).reset_index(drop=True)

        r = backtest(df, sl_mult=sl, tp_mult=tp)
        if r:
            r["ao_fast"] = fast; r["ao_slow"] = slow
            results.append(r)

    results.sort(key=lambda x: x["sharpe"], reverse=True)

    print(f"\n{'Fast':>5s} {'Slow':>5s} | {'Trades':>6s} {'WR%':>5s} {'PnL%':>8s} "
          f"{'Sharpe':>7s} {'PF':>6s} {'MaxDD':>7s}")
    print("-" * 55)
    for r in results[:15]:
        marker = " <-- LIVE" if r["ao_fast"] == 7 and r["ao_slow"] == 34 else ""
        marker = " <-- NEW" if r == results[0] else marker
        print(f"{r['ao_fast']:>5d} {r['ao_slow']:>5d} | {r['trades']:>6d} {r['winrate']:>4.0f}% "
              f"{r['total_pnl']:>+7.1f}% {r['sharpe']:>7.2f} {r['pf']:>5.2f} "
              f"{r['max_dd']:>6.1f}%{marker}")

    best = results[0]
    print(f"\n>>> Best AO: {best['ao_fast']}/{best['ao_slow']} (Sharpe={best['sharpe']:.2f})")
    return best["ao_fast"], best["ao_slow"]


# ═══════════════════════════════════════════════════════════════════════
#  TEST 4: FUNDING RATE THRESHOLDS
# ═══════════════════════════════════════════════════════════════════════

def test4_funding(raw_df, sl, tp, st_period, st_mult, ao_fast, ao_slow):
    print("\n" + "=" * 90)
    print(f"TEST 4: FUNDING RATE THRESHOLDS")
    print("=" * 90)

    fr_thresholds = [0.00005, 0.0001, 0.00015, 0.0002, 0.0003, 0.0005, 0.001, 999]
    # 999 = FR disabled

    df = calc_supertrend(raw_df, period=st_period, multiplier=st_mult)
    df = calc_ao(df, fast=ao_fast, slow=ao_slow)
    df = df.dropna(subset=["atr", "ao"]).reset_index(drop=True)

    results = []
    for fr_thresh in fr_thresholds:
        use_fr = fr_thresh < 100
        r = backtest(df, sl_mult=sl, tp_mult=tp,
                     fr_long_max=fr_thresh, fr_short_min=-fr_thresh,
                     use_fr=use_fr)
        if r:
            r["fr_thresh"] = fr_thresh if use_fr else "OFF"
            results.append(r)

    print(f"\n{'FR Thresh':>12s} | {'Trades':>6s} {'WR%':>5s} {'PnL%':>8s} "
          f"{'Sharpe':>7s} {'PF':>6s} {'MaxDD':>7s}")
    print("-" * 60)
    for r in results:
        fr_str = "OFF" if r["fr_thresh"] == "OFF" else f"±{r['fr_thresh']:.5f}"
        marker = " <-- LIVE" if r["fr_thresh"] == 0.0001 else ""
        marker = " <-- NEW" if r == max(results, key=lambda x: x["sharpe"]) else marker
        print(f"{fr_str:>12s} | {r['trades']:>6d} {r['winrate']:>4.0f}% "
              f"{r['total_pnl']:>+7.1f}% {r['sharpe']:>7.2f} {r['pf']:>5.2f} "
              f"{r['max_dd']:>6.1f}%{marker}")

    best = max(results, key=lambda x: x["sharpe"])
    use_fr = best["fr_thresh"] != "OFF"
    fr_val = best["fr_thresh"] if use_fr else 0.0001
    print(f"\n>>> Best FR: {'±' + str(fr_val) if use_fr else 'OFF'} (Sharpe={best['sharpe']:.2f})")
    return use_fr, fr_val


