#  TEST 1: SL/TP FEIN-GRID
# ═══════════════════════════════════════════════════════════════════════

def test1_sl_tp(raw_df):
    print("\n" + "=" * 90)
    print("TEST 1: SL/TP FEIN-GRID (ST: ATR14 × 2.0, AO 7/34 + FR)")
    print("=" * 90)

    df = calc_supertrend(raw_df, period=14, multiplier=2.0)
    df = calc_ao(df, fast=7, slow=34)
    df = df.dropna(subset=["atr", "ao"]).reset_index(drop=True)

    sl_values = [0.5, 1.0, 1.5, 2.0, 2.5, 3.0, 3.5, 4.0]
    tp_values = [1.0, 1.5, 2.0, 2.5, 3.0, 3.5, 4.0, 4.5, 5.0, 6.0, 8.0]

    results = []
    for sl, tp in product(sl_values, tp_values):
        if tp <= sl: continue
        r = backtest(df, sl_mult=sl, tp_mult=tp)
        if r:
            r["sl"] = sl; r["tp"] = tp; r["rr"] = tp / sl
            results.append(r)

    results.sort(key=lambda x: x["sharpe"], reverse=True)

    print(f"\n{'SL':>4s} {'TP':>4s} {'R:R':>5s} | {fmt_result.__doc__ or 'Results'}")
    print(f"{'SL':>4s} {'TP':>4s} {'R:R':>5s} | {'Trades':>6s} {'WR%':>5s} {'PnL%':>8s} "
          f"{'Sharpe':>7s} {'PF':>6s} {'MaxDD':>7s} {'AvgBars':>8s}")
    print("-" * 75)
    for r in results[:20]:
        marker = " <-- LIVE" if r["sl"] == 2.0 and r["tp"] == 3.0 else ""
        marker = " <-- NEW" if r == results[0] else marker
        print(f"{r['sl']:>4.1f} {r['tp']:>4.1f} {r['rr']:>5.2f} | {r['trades']:>6d} {r['winrate']:>4.0f}% "
              f"{r['total_pnl']:>+7.1f}% {r['sharpe']:>7.2f} {r['pf']:>5.2f} "
              f"{r['max_dd']:>6.1f}% {r['avg_bars']:>7.1f}{marker}")

    best = results[0]
    print(f"\n>>> Best SL/TP: {best['sl']}/{best['tp']} (Sharpe={best['sharpe']:.2f})")
    return best["sl"], best["tp"]


