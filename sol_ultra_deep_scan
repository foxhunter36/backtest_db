def test5_volume(raw_df, sl, tp, st_period, st_mult, ao_fast, ao_slow, use_fr, fr_val):
    print("\n" + "=" * 90)
    print(f"TEST 5: VOLUME FILTER")
    print("=" * 90)

    vol_configs = [
        ("OFF", 20, 0.0, False),
        ("SMA20 × 0.5", 20, 0.5, True),
        ("SMA20 × 0.8", 20, 0.8, True),
        ("SMA20 × 1.0", 20, 1.0, True),
        ("SMA20 × 1.2", 20, 1.2, True),
        ("SMA20 × 1.5", 20, 1.5, True),
        ("SMA20 × 2.0", 20, 2.0, True),
        ("SMA10 × 1.0", 10, 1.0, True),
        ("SMA30 × 1.0", 30, 1.0, True),
        ("SMA50 × 1.0", 50, 1.0, True),
    ]

    results = []
    for name, sma_per, thresh, use_vol in vol_configs:
        df = calc_supertrend(raw_df, period=st_period, multiplier=st_mult)
        df = calc_ao(df, fast=ao_fast, slow=ao_slow)
        df = calc_volume_filter(df, sma_period=sma_per, threshold=thresh)
        df = df.dropna(subset=["atr", "ao"]).reset_index(drop=True)

        r = backtest(df, sl_mult=sl, tp_mult=tp,
                     fr_long_max=fr_val, fr_short_min=-fr_val,
                     use_fr=use_fr, use_vol=use_vol)
        if r:
            r["vol_config"] = name
            results.append(r)

    print(f"\n{'Volume':>16s} | {'Trades':>6s} {'WR%':>5s} {'PnL%':>8s} "
          f"{'Sharpe':>7s} {'PF':>6s} {'MaxDD':>7s}")
    print("-" * 60)
    for r in results:
        marker = " <-- NEW" if r == max(results, key=lambda x: x["sharpe"]) else ""
        print(f"{r['vol_config']:>16s} | {r['trades']:>6d} {r['winrate']:>4.0f}% "
              f"{r['total_pnl']:>+7.1f}% {r['sharpe']:>7.2f} {r['pf']:>5.2f} "
              f"{r['max_dd']:>6.1f}%{marker}")

    best = max(results, key=lambda x: x["sharpe"])
    print(f"\n>>> Best Volume: {best['vol_config']} (Sharpe={best['sharpe']:.2f})")


