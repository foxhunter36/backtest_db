#  TEST 3: EXIT STRATEGY COMPARISON
# ═══════════════════════════════════════════════════════════════════════

def test_exit_strategy(conn, best_sl, best_tp, best_period, best_mult):
    print("\n" + "=" * 100)
    print(f"TEST 3: EXIT STRATEGY (ST: ATR{best_period} × {best_mult}, AO+FR)")
    print("=" * 100)

    strategies = [
        ("SL/TP + Flip", True, best_sl, best_tp),
        ("Flip Only (kein SL/TP)", False, 999, 999),
        ("Tight SL/TP (1.5/2)", True, 1.5, 2.0),
        ("Wide SL/TP (3/5)", True, 3.0, 5.0),
    ]

    for name, use_sl_tp, sl, tp in strategies:
        sharpes = []
        pnls = []
        total_trades = 0
        all_exits = {}

        for sym in COINS:
            df = load_coin_data(conn, sym)
            df = calc_supertrend(df, period=best_period, multiplier=best_mult)
            df = calc_ao(df)
            df = df.dropna(subset=["atr", "ao"]).reset_index(drop=True)

            r = backtest(df, sl_mult=sl, tp_mult=tp, use_sl_tp=use_sl_tp)
            if r:
                sharpes.append(r["sharpe"])
                pnls.append(r["total_pnl"])
                total_trades += r["trades"]
                for k, v in r["exits"].items():
                    all_exits[k] = all_exits.get(k, 0) + v

        avg_sh = np.mean(sharpes) if sharpes else 0
        avg_pnl = np.mean(pnls) if pnls else 0
        profitable = sum(1 for p in pnls if p > 0)
        exit_str = " | ".join(f"{k}:{v}" for k, v in sorted(all_exits.items()))

        print(f"\n  {name}:")
        print(f"    Sharpe: {avg_sh:.2f} | PnL: {avg_pnl:+.1f}% | "
              f"Trades: {total_trades} | Profitable: {profitable}/{len(COINS)}")
        print(f"    Exits: {exit_str}")


