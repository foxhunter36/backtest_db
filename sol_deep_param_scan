    results = []
    total_combos = len(atr_periods) * len(st_multipliers)
    done = 0

    for period, mult in product(atr_periods, st_multipliers):
        done += 1
        combo_sharpes = []
        combo_pnls = []
        combo_trades = 0

        for sym in COINS:
            df = load_coin_data(conn, sym)
            df = calc_supertrend(df, period=period, multiplier=mult)
            df = calc_ao(df)
            df = df.dropna(subset=["atr", "ao"]).reset_index(drop=True)

            r = backtest(df, sl_mult=best_sl, tp_mult=best_tp)
            if r:
                combo_sharpes.append(r["sharpe"])
                combo_pnls.append(r["total_pnl"])
                combo_trades += r["trades"]

        if combo_sharpes:
            results.append({
                "period": period, "mult": mult,
                "avg_sharpe": np.mean(combo_sharpes),
                "avg_pnl": np.mean(combo_pnls),
                "total_trades": combo_trades,
                "coins_profitable": sum(1 for p in combo_pnls if p > 0),
            })

        if done % 5 == 0:
            print(f"  Progress: {done}/{total_combos}")

    results.sort(key=lambda x: x["avg_sharpe"], reverse=True)

    print(f"\n{'Period':>7s} {'Mult':>5s} {'AvgSharpe':>10s} {'AvgPnL%':>9s} "
          f"{'Trades':>7s} {'Profitable':>11s}")
    print("-" * 60)
    for r in results:
        marker = " ***" if r["period"] == 14 and r["mult"] == 2.0 else ""
        print(f"{r['period']:>7d} {r['mult']:>5.1f} {r['avg_sharpe']:>10.2f} "
              f"{r['avg_pnl']:>+8.1f}% {r['total_trades']:>7d} "
              f"{r['coins_profitable']}/{len(COINS)}{marker}")

    print("\n*** = aktuelles Live-Setup")
    return results


