def test1_filters(df, days):
    print("\n" + "=" * 90)
    print("TEST 1: FILTER COMBINATIONS (AO × FR)")
    print("=" * 90)
    print("  Alle Tests mit Live-Exit: Hybrid (Cat SL 6×ATR, Trail +3%/0.5×ATR)")

    configs = [
        ("AO + FR (LIVE)",       True,  True),
        ("AO only (kein FR)",    True,  False),
        ("FR only (kein AO)",    False, True),
        ("Keine Filter",         False, False),
    ]

    print(f"\n  {'Config':<25s} | {fmt_header()}")
    print("-" * 100)

    results = {}
    for name, ao_on, fr_on in configs:
        trades = backtest_hybrid(df, ao_enabled=ao_on, fr_enabled=fr_on)
        r = compute_stats(trades, days)
        marker = " <-- LIVE" if ao_on and fr_on else ""
        if r:
            print(f"  {name:<25s} | {fmt(r)}{marker}")
            results[name] = r

    # FR Impact Detail
    if "AO + FR (LIVE)" in results and "AO only (kein FR)" in results:
        live = results["AO + FR (LIVE)"]
        no_fr = results["AO only (kein FR)"]
        blocked = no_fr["trades"] - live["trades"]
        sharpe_diff = live["sharpe"] - no_fr["sharpe"]
        pnl_diff = live["total_pnl"] - no_fr["total_pnl"]
        print(f"\n  FR IMPACT:")
        print(f"    Trades blockiert durch FR: {blocked}")
        print(f"    Sharpe Δ:  {sharpe_diff:+.2f} ({'besser' if sharpe_diff > 0 else 'schlechter'} mit FR)")
        print(f"    PnL Δ:     {pnl_diff:+.1f}% ({'besser' if pnl_diff > 0 else 'schlechter'} mit FR)")
        print(f"    MaxDD Δ:   {live['max_dd'] - no_fr['max_dd']:+.1f}%")
        print(f"    WR Δ:      {live['winrate'] - no_fr['winrate']:+.1f}%")

    return results


