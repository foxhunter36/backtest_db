def test8_risk_metrics(raw, days, best_st_period, best_st_mult, best_ao_fast,
                       best_ao_slow, best_trail_act, best_trail_off, best_cat_sl):
    print("\n" + "=" * 90)
    print("TEST 8: DETAILED RISK METRICS")
    print("=" * 90)

    configs = [
        ("LIVE",
         dict(st_p=14, st_m=2.0, ao_f=7, ao_s=34,
              trail_act=3.0, trail_off=0.5, cat_sl=6.0)),
        ("OPTIMIZED",
         dict(st_p=best_st_period, st_m=best_st_mult,
              ao_f=best_ao_fast, ao_s=best_ao_slow,
              trail_act=best_trail_act, trail_off=best_trail_off,
              cat_sl=best_cat_sl if best_cat_sl else 6.0)),
    ]

    for name, p in configs:
        df = prepare_df(raw, st_period=p["st_p"], st_mult=p["st_m"],
                        ao_fast=p["ao_f"], ao_slow=p["ao_s"])
        trades = backtest_hybrid(df, trail_act=p["trail_act"], trail_off=p["trail_off"],
                                 catastrophe_sl_mult=p["cat_sl"])
        r = compute_stats(trades, days)
        if not r:
            continue

        exits = " | ".join(f"{k}:{v}" for k, v in sorted(r["exits"].items()))
        print(f"\n  {name} — ST({p['st_p']},{p['st_m']}) AO({p['ao_f']},{p['ao_s']}) "
              f"Trail({p['trail_act']}/{p['trail_off']}) Cat={p['cat_sl']}:")
        print(f"    Trades:             {r['trades']:>6d} (L:{r['longs']} S:{r['shorts']})")
        print(f"    Win Rate:           {r['winrate']:>6.1f}%")
        print(f"    Total PnL:          {r['total_pnl']:>+6.1f}%")
        print(f"    Avg PnL/Trade:      {r['avg_pnl']:>+6.3f}%")
        print(f"    Std PnL:            {r['std_pnl']:>6.3f}%")
        print(f"    Avg Win:            {r['avg_win']:>+6.3f}%")
        print(f"    Avg Loss:           {r['avg_loss']:>+6.3f}%")
        print(f"    Payoff Ratio:       {r['payoff']:>6.2f}")
        print(f"    Max Drawdown:       {r['max_dd']:>6.1f}%")
        print(f"    Avg Bars/Trade:     {r['avg_bars']:>6.1f}")
        print(f"    Max Consec Wins:    {r['max_consec_wins']:>6d}")
        print(f"    Max Consec Losses:  {r['max_consec_losses']:>6d}")
        print(f"    ─── Ratios ───")
        print(f"    Sharpe:             {r['sharpe']:>6.2f}")
        print(f"    Sortino:            {r['sortino']:>6.2f}")
        print(f"    Calmar:             {r['calmar']:>6.2f}")
        print(f"    Profit Factor:      {r['pf']:>6.2f}")
        print(f"    Recovery Factor:    {r['recovery']:>6.2f}")
        print(f"    Skewness:           {r['skewness']:>+6.2f}")
        print(f"    Kurtosis:           {r['kurtosis']:>+6.2f}")
        print(f"    Exits:              {exits}")


