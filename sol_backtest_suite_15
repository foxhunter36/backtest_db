def test5_catastrophe_sl(df, days, best_trail_act, best_trail_off):
    print("\n" + "=" * 90)
    print(f"TEST 5: CATASTROPHE SL SCAN (Trail: +{best_trail_act}%/{best_trail_off}×ATR)")
    print("=" * 90)

    cat_mults = [None, 4.0, 5.0, 6.0, 7.0, 8.0, 10.0]

    results = []
    for cat in cat_mults:
        trades = backtest_hybrid(df, trail_act=best_trail_act, trail_off=best_trail_off,
                                 catastrophe_sl_mult=cat)
        r = compute_stats(trades, days)
        if r:
            r["cat_sl"] = cat if cat else 0
            results.append(r)

    results.sort(key=lambda x: x["sharpe"], reverse=True)

    print(f"\n  {'CatSL':>6s} | {fmt_header()}")
    print("-" * 90)
    for r in results:
        label = f"{r['cat_sl']:.0f}×ATR" if r["cat_sl"] > 0 else "OFF"
        marker = " <-- LIVE" if r["cat_sl"] == 6.0 else ""
        marker = " <-- BEST" if r == results[0] else marker
        print(f"  {label:>6s} | {fmt(r)}{marker}")

    best = results[0]
    best_cat = best["cat_sl"] if best["cat_sl"] > 0 else None
    print(f"\n>>> Best Cat SL: {best_cat if best_cat else 'OFF'} (Sharpe={best['sharpe']:.2f})")
    return best_cat


