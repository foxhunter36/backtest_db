    print(f"    Filter:        AO=ON, FR=ON")
    print(f"\n  vs. Live:")
    print(f"    Supertrend:    ATR(14) × 2.0")
    print(f"    AO:            Fast=7 Slow=34")
    print(f"    Trail:         +3.0% / 0.5×ATR")
    print(f"    Catastrophe:   6.0×ATR")
    print(f"    Filter:        AO=ON, FR=ON")


if __name__ == "__main__":
    main()