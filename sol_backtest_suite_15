def test6_comparison(raw, days, best_st_period, best_st_mult, best_ao_fast,
                     best_ao_slow, best_trail_act, best_trail_off, best_cat_sl):
    print("\n" + "=" * 90)
    print("TEST 6: COMBINED COMPARISON")
    print("=" * 90)

    configs = [
        ("LIVE (deployed)",
         dict(st_p=14, st_m=2.0, ao_f=7, ao_s=34,
              trail_act=3.0, trail_off=0.5, cat_sl=6.0)),
        ("OPTIMIZED",
         dict(st_p=best_st_period, st_m=best_st_mult,
              ao_f=best_ao_fast, ao_s=best_ao_slow,
              trail_act=best_trail_act, trail_off=best_trail_off,
              cat_sl=best_cat_sl if best_cat_sl else 6.0)),
    ]

    print(f"\n  {'Config':<40s} | {fmt_header()}")
    print("-" * 110)

    for name, p in configs:
        df = prepare_df(raw, st_period=p["st_p"], st_mult=p["st_m"],
                        ao_fast=p["ao_f"], ao_slow=p["ao_s"])
        trades = backtest_hybrid(df, trail_act=p["trail_act"], trail_off=p["trail_off"],
                                 catastrophe_sl_mult=p["cat_sl"])
        r = compute_stats(trades, days)
        desc = (f"ST({p['st_p']},{p['st_m']}) AO({p['ao_f']},{p['ao_s']}) "
                f"T({p['trail_act']}/{p['trail_off']}) Cat={p['cat_sl']}")
        print(f"  {name:<40s} | {fmt(r)}")
        print(f"    {desc}")


