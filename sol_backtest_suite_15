    print(f"TEST 3: AO PARAMETER SCAN (ST: ATR{best_st_period}×{best_st_mult})")
    print("=" * 90)

    fasts = [5, 7, 14, 21, 28]
    slows = [34, 55, 89, 120, 144]

    results = []
    for f, s in product(fasts, slows):
        if f >= s:
            continue
        df = prepare_df(raw, st_period=best_st_period, st_mult=best_st_mult,
                        ao_fast=f, ao_slow=s)
        trades = backtest_hybrid(df)
        r = compute_stats(trades, days)
        if r:
            r["ao_fast"] = f
            r["ao_slow"] = s
            results.append(r)

    results.sort(key=lambda x: x["sharpe"], reverse=True)

    print(f"\n  {'Fast':>5s} {'Slow':>5s} | {fmt_header()}")
    print("-" * 90)
    for r in results[:20]:
        marker = " <-- LIVE" if r["ao_fast"] == 7 and r["ao_slow"] == 34 else ""
        marker = " <-- BEST" if r == results[0] else marker
        print(f"  {r['ao_fast']:>5d} {r['ao_slow']:>5d} | {fmt(r)}{marker}")

    best = results[0]
    print(f"\n>>> Best AO: Fast={best['ao_fast']} Slow={best['ao_slow']} "
          f"(Sharpe={best['sharpe']:.2f})")
    return best["ao_fast"], best["ao_slow"]


