#  TEST 7: WALK-FORWARD VALIDATION (70/30)
# ═══════════════════════════════════════════════════════════════════════

def test7_walkforward(raw, best_st_period, best_st_mult, best_ao_fast,
                      best_ao_slow, best_trail_act, best_trail_off, best_cat_sl):
    print("\n" + "=" * 90)
    print("TEST 7: WALK-FORWARD VALIDATION (70/30)")
    print("=" * 90)

    split = int(len(raw) * 0.7)
    train_raw = raw.iloc[:split].reset_index(drop=True)
    test_raw = raw.iloc[split:].reset_index(drop=True)
    train_days = len(train_raw) / 96
    test_days = len(test_raw) / 96

    print(f"  Train: {len(train_raw)} bars ({train_days:.0f} Tage)")
    print(f"  Test:  {len(test_raw)} bars ({test_days:.0f} Tage)")

    configs = [
        ("LIVE",
         dict(st_p=14, st_m=2.0, ao_f=7, ao_s=34,
              trail_act=3.0, trail_off=0.5, cat_sl=6.0)),
        ("OPTIMIZED",
         dict(st_p=best_st_period, st_m=best_st_mult,
              ao_f=best_ao_fast, ao_s=best_ao_slow,
              trail_act=best_trail_act, trail_off=best_trail_off,
              cat_sl=best_cat_sl if best_cat_sl else 6.0)),
    ]

    print(f"\n  {'Config':<20s} | {'Set':<6s} | {fmt_header()}")
    print("-" * 100)

    for name, p in configs:
        for label, data, d in [("Train", train_raw, train_days),
                                ("Test", test_raw, test_days)]:
            df = prepare_df(data, st_period=p["st_p"], st_mult=p["st_m"],
                            ao_fast=p["ao_f"], ao_slow=p["ao_s"])
            trades = backtest_hybrid(df, trail_act=p["trail_act"], trail_off=p["trail_off"],
                                     catastrophe_sl_mult=p["cat_sl"])
            r = compute_stats(trades, d)
            print(f"  {name:<20s} | {label:<6s} | {fmt(r)}")

    # FR Robustheit in Walk-Forward
    print(f"\n  --- FR IMPACT Walk-Forward ---")
    for label, data, d in [("Train", train_raw, train_days),
                            ("Test", test_raw, test_days)]:
        df = prepare_df(data)
        t_on = backtest_hybrid(df, ao_enabled=True, fr_enabled=True)
        t_off = backtest_hybrid(df, ao_enabled=True, fr_enabled=False)
        r_on = compute_stats(t_on, d)
        r_off = compute_stats(t_off, d)
        if r_on and r_off:
            print(f"  {label:<6s} FR ON:  Sharpe={r_on['sharpe']:.2f} PnL={r_on['total_pnl']:+.1f}% "
                  f"Trades={r_on['trades']}")
            print(f"  {label:<6s} FR OFF: Sharpe={r_off['sharpe']:.2f} PnL={r_off['total_pnl']:+.1f}% "
                  f"Trades={r_off['trades']}")
            delta = r_on['sharpe'] - r_off['sharpe']
            print(f"  {label:<6s} Δ Sharpe: {delta:+.2f} "
                  f"({'FR hilft' if delta > 0 else 'FR schadet'})")


