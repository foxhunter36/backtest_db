def load_data():
    conn = psycopg2.connect(PG_DSN)
    raw = pd.read_sql_query(
        f"SELECT timestamp, open, high, low, close, volume FROM {TABLE} "
        f"WHERE symbol=%s ORDER BY timestamp", conn, params=(SYMBOL,))
    fr = pd.read_sql_query(
        "SELECT timestamp, funding_rate FROM funding_rate "
        "WHERE symbol=%s ORDER BY timestamp", conn, params=(SYMBOL,))
    conn.close()

    if len(fr) > 0:
        raw = pd.merge_asof(raw.sort_values("timestamp"), fr.sort_values("timestamp"),
                            on="timestamp", direction="backward")
    else:
        raw["funding_rate"] = np.nan

    print(f"  {len(raw)} Candles geladen ({len(raw)/96:.0f} Tage)")
    print(f"  Funding Rate Datenpunkte: {fr['funding_rate'].notna().sum() if len(fr) > 0 else 0}")
    return raw


# ═══════════════════════════════════════════════════════════════════════
#  INDICATORS
# ═══════════════════════════════════════════════════════════════════════

def calc_atr(df, period):
    tr = pd.concat([
        df["high"] - df["low"],
        (df["high"] - df["close"].shift(1)).abs(),
        (df["low"] - df["close"].shift(1)).abs()
    ], axis=1).max(axis=1)
    return tr.ewm(alpha=1.0 / period, min_periods=period, adjust=False).mean()


def calc_supertrend(df, period=ST_ATR_PERIOD, multiplier=ST_MULTIPLIER):
    df = df.copy()
    atr = calc_atr(df, period)
    df["atr"] = atr
    hl2 = (df["high"] + df["low"]) / 2.0
    upper = (hl2 + multiplier * atr).values
    lower = (hl2 - multiplier * atr).values
    close = df["close"].values
    n = len(df)

    fu = np.full(n, np.nan)
    fl = np.full(n, np.nan)
    d = np.zeros(n, dtype=int)

    s = period
    if s >= n:
        df["st_direction"] = 0
        df["st_long"] = False
        df["st_short"] = False
        return df

    fu[s] = upper[s]
    fl[s] = lower[s]
    d[s] = -1

    for i in range(s + 1, n):
        fu[i] = upper[i] if (upper[i] < fu[i - 1] or close[i - 1] > fu[i - 1]) else fu[i - 1]
        fl[i] = lower[i] if (lower[i] > fl[i - 1] or close[i - 1] < fl[i - 1]) else fl[i - 1]
        if d[i - 1] == 1:
            d[i] = -1 if close[i] < fl[i] else 1
        else:
            d[i] = 1 if close[i] > fu[i] else -1

    df["st_direction"] = d
    ds = pd.Series(d, index=df.index)
    df["st_long"] = (ds == 1) & (ds.shift(1) == -1)
    df["st_short"] = (ds == -1) & (ds.shift(1) == 1)
    return df


def calc_ao(df, fast=AO_FAST, slow=AO_SLOW):
    df = df.copy()
    mid = (df["high"] + df["low"]) / 2.0
    df["ao"] = mid.rolling(fast).mean() - mid.rolling(slow).mean()
    return df


def prepare_df(raw, st_period=ST_ATR_PERIOD, st_mult=ST_MULTIPLIER,
               ao_fast=AO_FAST, ao_slow=AO_SLOW):
    """Berechnet alle Indikatoren auf raw-Daten."""
    df = calc_supertrend(raw, st_period, st_mult)
    df = calc_ao(df, ao_fast, ao_slow)
    df = df.dropna(subset=["atr", "ao"]).reset_index(drop=True)
    return df


# ═══════════════════════════════════════════════════════════════════════
#  SIGNAL CHECK (konfigurierbar)
# ═══════════════════════════════════════════════════════════════════════

def check_signal(row, ao_enabled=True, fr_enabled=True,
                 fr_long_max=FUNDING_LONG_MAX, fr_short_min=FUNDING_SHORT_MIN):
    """Signal-Check mit konfigurierbaren Filtern."""
    sig = None
    if row["st_long"]:
        sig = "long"
    elif row["st_short"]:
        sig = "short"
    if not sig:
        return None

    # AO Filter
    if ao_enabled:
        if sig == "long" and row["ao"] <= 0:
            return None
        if sig == "short" and row["ao"] >= 0:
            return None

    # Funding Rate Filter
    if fr_enabled:
        fr = row.get("funding_rate", np.nan)
        if pd.notna(fr):
            if sig == "long" and fr > fr_long_max:
                return None
            if sig == "short" and fr < fr_short_min:
                return None

    if row["atr"] <= 0:
        return None

    return sig


# ═══════════════════════════════════════════════════════════════════════
#  BACKTEST ENGINE — Hybrid Exit (Live-Logik)
# ═══════════════════════════════════════════════════════════════════════

def backtest_hybrid(df, trail_act=TRAIL_ACT_PCT, trail_off=TRAIL_ATR_MULT,
                    catastrophe_sl_mult=CATASTROPHE_SL_MULT,
                    ao_enabled=True, fr_enabled=True,
                    fr_long_max=FUNDING_LONG_MAX, fr_short_min=FUNDING_SHORT_MIN):
    """
    Hybrid Exit: Kein normaler SL. Catastrophe SL als Sicherheitsnetz.
    Trail bei +trail_act%, Offset trail_off×ATR. Vor Trail nur ST-Flip.
    """
    trades = []
    pos = None

    for i in range(1, len(df)):
        row = df.iloc[i]
        c, h, l = row["close"], row["high"], row["low"]

        if pos:
            pnl_now = ((c - pos["entry"]) / pos["entry"] * 100
                       if pos["side"] == "long"
                       else (pos["entry"] - c) / pos["entry"] * 100)

            # Trail Activation
            if not pos["trail_active"] and pnl_now >= trail_act:
                off = row["atr"] * trail_off
                pos["trail_price"] = (c - off) if pos["side"] == "long" else (c + off)
                pos["trail_active"] = True
                pos["trail_off_abs"] = off

            # Trail Update
            if pos["trail_active"]:
                if pos["side"] == "long":
                    nt = h - pos["trail_off_abs"]
                    if nt > pos["trail_price"]:
                        pos["trail_price"] = nt
                else:
                    nt = l + pos["trail_off_abs"]
                    if nt < pos["trail_price"]:
                        pos["trail_price"] = nt

            # Exit Checks
            ex = False
            if pos["side"] == "long":
                if catastrophe_sl_mult and l <= pos["cat_sl"]:
                    pnl = (pos["cat_sl"] - pos["entry"]) / pos["entry"] * 100
                    trades.append({"pnl": pnl, "exit": "CAT_SL",
                                   "bars": i - pos["bar"], "side": "long"})
                    ex = True
                elif pos["trail_active"] and l <= pos["trail_price"]:
                    pnl = (pos["trail_price"] - pos["entry"]) / pos["entry"] * 100
                    trades.append({"pnl": pnl, "exit": "TRAIL",
                                   "bars": i - pos["bar"], "side": "long"})
                    ex = True
                elif row["st_short"]:
                    pnl = (c - pos["entry"]) / pos["entry"] * 100
                    trades.append({"pnl": pnl, "exit": "FLIP",
                                   "bars": i - pos["bar"], "side": "long"})
                    ex = True
            else:
                if catastrophe_sl_mult and h >= pos["cat_sl"]:
                    pnl = (pos["entry"] - pos["cat_sl"]) / pos["entry"] * 100
                    trades.append({"pnl": pnl, "exit": "CAT_SL",
                                   "bars": i - pos["bar"], "side": "short"})
                    ex = True
                elif pos["trail_active"] and h >= pos["trail_price"]:
                    pnl = (pos["entry"] - pos["trail_price"]) / pos["entry"] * 100
                    trades.append({"pnl": pnl, "exit": "TRAIL",
                                   "bars": i - pos["bar"], "side": "short"})
                    ex = True
                elif row["st_long"]:
                    pnl = (pos["entry"] - c) / pos["entry"] * 100
                    trades.append({"pnl": pnl, "exit": "FLIP",
                                   "bars": i - pos["bar"], "side": "short"})
                    ex = True

            if ex:
                pos = None
            else:
                continue

        if pos:
            continue

        sig = check_signal(row, ao_enabled=ao_enabled, fr_enabled=fr_enabled,
                           fr_long_max=fr_long_max, fr_short_min=fr_short_min)
        if not sig:
            continue

        atr_val = row["atr"]
        if sig == "long":
            cat_sl = c - catastrophe_sl_mult * atr_val if catastrophe_sl_mult else 0
            pos = {"side": "long", "entry": c, "cat_sl": cat_sl, "bar": i,
                   "trail_active": False, "trail_price": 0, "trail_off_abs": 0}
        else:
            cat_sl = c + catastrophe_sl_mult * atr_val if catastrophe_sl_mult else 999999
            pos = {"side": "short", "entry": c, "cat_sl": cat_sl, "bar": i,
                   "trail_active": False, "trail_price": 0, "trail_off_abs": 0}

    # Close open
    if pos:
        c = df.iloc[-1]["close"]
        if pos["side"] == "long":
            pnl = (c - pos["entry"]) / pos["entry"] * 100
        else:
            pnl = (pos["entry"] - c) / pos["entry"] * 100
        trades.append({"pnl": pnl, "exit": "END", "bars": len(df) - pos["bar"],
                       "side": pos["side"]})

    return trades


# ═══════════════════════════════════════════════════════════════════════
#  STATS / METRICS
# ═══════════════════════════════════════════════════════════════════════

def compute_stats(trades, days=None):
    """Berechnet alle Metriken aus Trade-Liste."""
    if not trades:
        return None

    pnls = np.array([t["pnl"] - FEE_PCT * 2 for t in trades])
    bars = np.array([t["bars"] for t in trades])
    total = len(pnls)
    wins = (pnls > 0).sum()

    total_pnl = pnls.sum()
    avg_pnl = pnls.mean()
    std_pnl = pnls.std() if total > 1 else 0

    # Cumulative PnL & Drawdown
    cum = np.cumsum(pnls)
    running_max = np.maximum.accumulate(cum)
    drawdown = cum - running_max
    max_dd = drawdown.min() if len(drawdown) > 0 else 0

    # Win/Loss
    win_pnls = pnls[pnls > 0]
    loss_pnls = pnls[pnls <= 0]
    avg_win = win_pnls.mean() if len(win_pnls) > 0 else 0
    avg_loss = loss_pnls.mean() if len(loss_pnls) > 0 else 0
    win_rate = wins / total * 100

    # Profit Factor
    gross_profit = win_pnls.sum() if len(win_pnls) > 0 else 0
    gross_loss = abs(loss_pnls.sum()) if len(loss_pnls) > 0 else 0.001
    pf = gross_profit / gross_loss

    # Sharpe (annualisiert)
    if days and days > 0:
        trades_per_year = total / (days / 365)
    else:
        trades_per_year = total
    sharpe = avg_pnl / std_pnl * np.sqrt(trades_per_year) if std_pnl > 0 else 0

    # Sortino
    downside = pnls[pnls < 0]
    downside_std = np.sqrt(np.mean(downside ** 2)) if len(downside) > 0 else 0
    sortino = avg_pnl / downside_std * np.sqrt(trades_per_year) if downside_std > 0 else 0

    # Calmar
    annualized_return = total_pnl / (days / 365) if days and days > 0 else total_pnl
    calmar = annualized_return / abs(max_dd) if max_dd != 0 else 0

    # Consecutive
    max_cw = max_cl = cw = cl = 0
    for p in pnls:
        if p > 0:
            cw += 1; cl = 0; max_cw = max(max_cw, cw)
        else:
            cl += 1; cw = 0; max_cl = max(max_cl, cl)

    # Exits
    exits = {}
    for t in trades:
        exits[t["exit"]] = exits.get(t["exit"], 0) + 1

    # Side split
    longs = sum(1 for t in trades if t["side"] == "long")
    shorts = sum(1 for t in trades if t["side"] == "short")

    # Payoff Ratio
    payoff = avg_win / abs(avg_loss) if avg_loss != 0 else float("inf")

    # Recovery Factor
    recovery = total_pnl / abs(max_dd) if max_dd != 0 else 0

    # Skewness / Kurtosis
    skew = sp_stats.skew(pnls) if total >= 3 else 0
    kurt = sp_stats.kurtosis(pnls) if total >= 4 else 0

    return {
        "trades": total, "wins": wins, "winrate": win_rate,
        "total_pnl": total_pnl, "avg_pnl": avg_pnl, "std_pnl": std_pnl,
        "avg_win": avg_win, "avg_loss": avg_loss, "payoff": payoff,
        "max_dd": max_dd, "avg_bars": bars.mean(),
        "sharpe": sharpe, "sortino": sortino, "calmar": calmar,
        "pf": pf, "recovery": recovery,
        "max_consec_wins": max_cw, "max_consec_losses": max_cl,
        "longs": longs, "shorts": shorts,
        "skewness": skew, "kurtosis": kurt,
        "exits": exits,
    }


def fmt(r):
    """Einzeilige Ausgabe einer Stats-Dict."""
    if not r:
        return "(keine Trades)"
    exits_str = " ".join(f"{k}:{v}" for k, v in sorted(r["exits"].items()))
    return (f"{r['trades']:>5d} {r['winrate']:>4.0f}% {r['total_pnl']:>+7.1f}% "
            f"{r['sharpe']:>6.2f} {r['sortino']:>7.2f} {r['pf']:>5.2f} "
            f"{r['max_dd']:>6.1f}%  {exits_str}")


def fmt_header():
    return (f"{'Trades':>5s} {'WR%':>4s} {'PnL%':>7s} {'Sharpe':>6s} "
            f"{'Sortino':>7s} {'PF':>5s} {'MaxDD':>6s}  Exits")


