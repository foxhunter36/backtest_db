def main():
    print("=" * 90)
    print("SOL SUPERTREND + AO — COMPREHENSIVE BACKTEST SUITE (15m)")
    print(f"Symbol: {SYMBOL} | Timeframe: 15m | Strategy: Supertrend + AO + FR + Hybrid Exit")
    print("=" * 90)

    raw = load_data()
    days = len(raw) / 96  # 96 candles/day for 15m

    # Prepare mit Live-Parametern für Tests die kein ST/AO-Scan brauchen
    df_live = prepare_df(raw)

    # Test 1: Filter Combinations (beantwortet FR-Frage)
    filter_results = test1_filters(df_live, days)

    # Test 2: Supertrend Parameter Grid
    best_st_period, best_st_mult = test2_supertrend(raw, days)

    # Test 3: AO Parameter Scan (mit bestem ST)
    best_ao_fast, best_ao_slow = test3_ao(raw, days, best_st_period, best_st_mult)

    # Prepare mit besten Indikatoren für Exit-Tests
    df_opt = prepare_df(raw, st_period=best_st_period, st_mult=best_st_mult,
                        ao_fast=best_ao_fast, ao_slow=best_ao_slow)

    # Test 4: Trail Grid
    best_trail_act, best_trail_off = test4_trail(df_opt, days)

    # Test 5: Catastrophe SL Scan
    best_cat_sl = test5_catastrophe_sl(df_opt, days, best_trail_act, best_trail_off)

    # Test 6: Combined Comparison
    test6_comparison(raw, days, best_st_period, best_st_mult, best_ao_fast,
                     best_ao_slow, best_trail_act, best_trail_off, best_cat_sl)

    # Test 7: Walk-Forward
    test7_walkforward(raw, best_st_period, best_st_mult, best_ao_fast,
                      best_ao_slow, best_trail_act, best_trail_off, best_cat_sl)

    # Test 8: Risk Metrics
    test8_risk_metrics(raw, days, best_st_period, best_st_mult, best_ao_fast,
                       best_ao_slow, best_trail_act, best_trail_off, best_cat_sl)

    # Summary
    print("\n" + "=" * 90)
    print("ZUSAMMENFASSUNG")
    print("=" * 90)
    print(f"  Optimale Parameter:")
    print(f"    Supertrend:    ATR({best_st_period}) × {best_st_mult}")
    print(f"    AO:            Fast={best_ao_fast} Slow={best_ao_slow}")
    print(f"    Trail:         +{best_trail_act}% / {best_trail_off}×ATR")
