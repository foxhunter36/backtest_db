#  TEST 2: SUPERTREND PARAMETER GRID
# ═══════════════════════════════════════════════════════════════════════

def test2_supertrend(raw, days):
    print("\n" + "=" * 90)
    print("TEST 2: SUPERTREND PARAMETER GRID (ATR Period × Multiplier)")
    print("=" * 90)

    periods = [14, 20, 28, 42, 56]
    multipliers = [1.5, 2.0, 2.5, 3.0, 3.5]

    results = []
    total = len(periods) * len(multipliers)
    done = 0

    for period, mult in product(periods, multipliers):
        done += 1
        if done % 5 == 0:
            print(f"  {done}/{total}...")
        df = prepare_df(raw, st_period=period, st_mult=mult)
        trades = backtest_hybrid(df)
        r = compute_stats(trades, days)
        if r:
            r["period"] = period
            r["mult"] = mult
            results.append(r)

    results.sort(key=lambda x: x["sharpe"], reverse=True)

    print(f"\n  {'Per':>4s} {'Mult':>5s} | {fmt_header()}")
    print("-" * 90)
    for r in results[:20]:
        marker = " <-- LIVE" if r["period"] == 14 and r["mult"] == 2.0 else ""
        marker = " <-- BEST" if r == results[0] else marker
        print(f"  {r['period']:>4d} {r['mult']:>5.1f} | {fmt(r)}{marker}")

    best = results[0]
    print(f"\n>>> Best ST: ATR({best['period']}) × {best['mult']} (Sharpe={best['sharpe']:.2f})")
    return best["period"], best["mult"]


