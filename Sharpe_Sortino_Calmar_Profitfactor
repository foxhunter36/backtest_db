    # ══════════════════════════════════════════════════════════════
    #  CONSENSUS RANKING
    # ══════════════════════════════════════════════════════════════
    print(f"\n{'='*100}")
    print("CONSENSUS RANKING (Durchschnitt aller Rankings)")
    print(f"{'='*100}")

    rank_metrics = ["sharpe", "sortino", "calmar", "profit_factor", "recovery_factor",
                    "upi", "tail_ratio"]
    scores = {m["label"]: 0 for m in all_metrics}

    for metric in rank_metrics:
        ranked = sorted(all_metrics, key=lambda x: x[metric], reverse=True)
        for rank, r in enumerate(ranked):
            scores[r["label"]] += rank + 1

    final_ranking = sorted(scores.items(), key=lambda x: x[1])
    print()
    for rank, (label, score) in enumerate(final_ranking, 1):
        m = next(r for r in all_metrics if r["label"] == label)
        print(f"  #{rank} (avg rank {score/len(rank_metrics):.1f}): {label}")
        print(f"      Sharpe={m['sharpe']:.2f} Sortino={m['sortino']:.2f} Calmar={m['calmar']:.2f} "
              f"PF={m['profit_factor']:.2f} PnL={m['total_pnl']:+.1f}%")


