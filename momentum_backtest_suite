def backtest_trail(df, bb_period=BB_PERIOD, bb_std=BB_STD, vol_mult=None,
                   sl_mult=SL_ATR_MULT, trail_act=TRAIL_ACT, trail_off=TRAIL_OFF,
                   use_fixed_tp=False, tp_mult=3.0, catastrophe_sl=None):
    """
    Momentum Bollinger Breakout Backtest.
    vol_mult=None: kein Volume-Filter
    vol_mult=1.8: Volume > SMA × 1.8
    use_fixed_tp=True: fixer TP statt Trail
    catastrophe_sl: nur als Sicherheitsnetz (kein normaler SL)
    """
    df = calc_bollinger(df, period=bb_period, std=bb_std)
    df = df.dropna(subset=["atr", "bb_upper", "bb_lower", "vol_sma"]).reset_index(drop=True)

    trades = []
    pos = None

    for i in range(1, len(df)):
        row = df.iloc[i]
        c, h, l = row["close"], row["high"], row["low"]

        if pos:
            # PnL
            if pos["side"] == "long":
                pnl_now = (c - pos["entry"]) / pos["entry"] * 100
            else:
                pnl_now = (pos["entry"] - c) / pos["entry"] * 100

            # Trail activation
            if not use_fixed_tp and not pos.get("trail_active") and pnl_now >= trail_act:
                off = row["atr"] * trail_off
                pos["trail_price"] = (c - off) if pos["side"] == "long" else (c + off)
                pos["trail_active"] = True
                pos["trail_off_abs"] = off

            # Trail update
            if pos.get("trail_active"):
                if pos["side"] == "long":
                    nt = h - pos["trail_off_abs"]
                    if nt > pos["trail_price"]: pos["trail_price"] = nt
                else:
                    nt = l + pos["trail_off_abs"]
                    if nt < pos["trail_price"]: pos["trail_price"] = nt

            # Exit checks
            ex = False
            if pos["side"] == "long":
                if sl_mult and l <= pos["sl"]:
                    trades.append({"pnl": (pos["sl"]-pos["entry"])/pos["entry"]*100, "exit": "SL", "bars": i-pos["bar"]})
                    ex = True
                elif catastrophe_sl and not sl_mult and l <= pos.get("cat_sl", 0):
                    trades.append({"pnl": (pos["cat_sl"]-pos["entry"])/pos["entry"]*100, "exit": "CAT_SL", "bars": i-pos["bar"]})
                    ex = True
                elif use_fixed_tp and h >= pos.get("tp", 999999):
                    trades.append({"pnl": (pos["tp"]-pos["entry"])/pos["entry"]*100, "exit": "TP", "bars": i-pos["bar"]})
                    ex = True
                elif pos.get("trail_active") and l <= pos["trail_price"]:
                    trades.append({"pnl": (pos["trail_price"]-pos["entry"])/pos["entry"]*100, "exit": "TRAIL", "bars": i-pos["bar"]})
                    ex = True
                elif c < row["bb_mid"]:  # Exit: price crosses back below BB mid
                    trades.append({"pnl": (c-pos["entry"])/pos["entry"]*100, "exit": "BB_MID", "bars": i-pos["bar"]})
                    ex = True
            else:
                if sl_mult and h >= pos["sl"]:
                    trades.append({"pnl": (pos["entry"]-pos["sl"])/pos["entry"]*100, "exit": "SL", "bars": i-pos["bar"]})
                    ex = True
                elif catastrophe_sl and not sl_mult and h >= pos.get("cat_sl", 999999):
                    trades.append({"pnl": (pos["entry"]-pos["cat_sl"])/pos["entry"]*100, "exit": "CAT_SL", "bars": i-pos["bar"]})
                    ex = True
                elif use_fixed_tp and l <= pos.get("tp", 0):
                    trades.append({"pnl": (pos["entry"]-pos["tp"])/pos["entry"]*100, "exit": "TP", "bars": i-pos["bar"]})
                    ex = True
                elif pos.get("trail_active") and h >= pos["trail_price"]:
                    trades.append({"pnl": (pos["entry"]-pos["trail_price"])/pos["entry"]*100, "exit": "TRAIL", "bars": i-pos["bar"]})
                    ex = True
                elif c > row["bb_mid"]:
                    trades.append({"pnl": (pos["entry"]-c)/pos["entry"]*100, "exit": "BB_MID", "bars": i-pos["bar"]})
                    ex = True

            if ex: pos = None
            else: continue

        if pos: continue

        # Signal
        sig = None
        if c > row["bb_upper"]: sig = "long"
        elif c < row["bb_lower"]: sig = "short"
        if not sig: continue

        # Volume filter
        if vol_mult is not None:
            if row["volume"] <= row["vol_sma"] * vol_mult:
                continue

        atr = row["atr"]
        if atr <= 0: continue

        if sig == "long":
            pos = {"side": "long", "entry": c, "bar": i, "trail_active": False,
                   "trail_price": 0, "trail_off_abs": 0}
            if sl_mult: pos["sl"] = c - sl_mult * atr
            if catastrophe_sl and not sl_mult: pos["cat_sl"] = c - catastrophe_sl * atr
            if use_fixed_tp: pos["tp"] = c + tp_mult * atr
        else:
            pos = {"side": "short", "entry": c, "bar": i, "trail_active": False,
                   "trail_price": 0, "trail_off_abs": 0}
            if sl_mult: pos["sl"] = c + sl_mult * atr
            if catastrophe_sl and not sl_mult: pos["cat_sl"] = c + catastrophe_sl * atr
            if use_fixed_tp: pos["tp"] = c - tp_mult * atr

    return analyze(trades)


def analyze(trades):
    if not trades: return None
    pnls = np.array([t["pnl"] - FEE_PCT*2 for t in trades])
    bars = np.array([t["bars"] for t in trades])
    wins = (pnls > 0).sum(); total = len(pnls)
    cum = np.cumsum(pnls)
    max_dd = (cum - np.maximum.accumulate(cum)).min() if len(cum) > 0 else 0
    sharpe = pnls.mean() / pnls.std() * np.sqrt(total) if pnls.std() > 0 else 0
    gp = pnls[pnls > 0].sum(); gl = abs(pnls[pnls <= 0].sum())
    pf = gp / gl if gl > 0 else float("inf")

    # Sortino
    down = pnls[pnls < 0]
    down_std = np.sqrt(np.mean(down**2)) if len(down) > 0 else 0
    days_approx = total * 2  # rough estimate
    tpy = total / (days_approx / 365) if days_approx > 0 else total
    sortino = pnls.mean() / down_std * np.sqrt(tpy) if down_std > 0 else 0

    # Calmar
    ann_ret = pnls.sum() / (days_approx / 365) if days_approx > 0 else pnls.sum()
    calmar = ann_ret / abs(max_dd) if max_dd != 0 else 0

    exits = {}
    for t in trades: exits[t["exit"]] = exits.get(t["exit"], 0) + 1

    return {
        "trades": total, "wins": wins, "winrate": wins/total*100,
        "total_pnl": pnls.sum(), "avg_pnl": pnls.mean(), "max_dd": max_dd,
        "sharpe": sharpe, "sortino": sortino, "calmar": calmar,
        "pf": pf, "avg_bars": bars.mean(), "exits": exits,
    }


def fmt(r):
    if not r: return "(keine Trades)"
    ex = " ".join(f"{k}:{v}" for k,v in sorted(r["exits"].items()))
    return (f"Tr={r['trades']:>4d} WR={r['winrate']:>4.0f}% PnL={r['total_pnl']:>+7.1f}% "
            f"Sh={r['sharpe']:>5.2f} So={r['sortino']:>5.2f} Ca={r['calmar']:>5.2f} "
            f"PF={r['pf']:>5.2f} DD={r['max_dd']:>6.1f}% | {ex}")


def load_coin(conn, symbol, table="kline_1h"):
    df = pd.read_sql_query(
        f"SELECT timestamp, open, high, low, close, volume FROM {table} "
        "WHERE symbol=%s ORDER BY timestamp", conn, params=(symbol,))
    return df


