def calc_atr(df, period=ATR_PERIOD):
    tr = pd.concat([df["high"]-df["low"], (df["high"]-df["close"].shift(1)).abs(),
                    (df["low"]-df["close"].shift(1)).abs()], axis=1).max(axis=1)
    return tr.ewm(alpha=1.0/period, min_periods=period, adjust=False).mean()


def calc_bollinger(df, period=BB_PERIOD, std=BB_STD):
    df = df.copy()
    df["atr"] = calc_atr(df)
    df["bb_mid"] = df["close"].rolling(period).mean()
    bb_std = df["close"].rolling(period).std()
    df["bb_upper"] = df["bb_mid"] + std * bb_std
    df["bb_lower"] = df["bb_mid"] - std * bb_std
    df["vol_sma"] = df["volume"].rolling(period).mean()
    return df


