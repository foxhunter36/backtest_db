"""
SOL Supertrend — Filter-Kombinations-Backtest
══════════════════════════════════════════════
Testet alle 16 Kombinationen der 4 Bestätigungsfilter (AO, Volume, OI, Funding)
mit Supertrend als Pflicht-Gate.

Läuft auf Trading Station, DB via Tailscale.

Usage:
    python sol_filter_backtest.py
"""

import psycopg2
import pandas as pd
import numpy as np
from itertools import product
from datetime import datetime

