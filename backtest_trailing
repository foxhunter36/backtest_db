"""
SOL Supertrend — Trailing Stop Parameter Scan
══════════════════════════════════════════════
Testet Trailing Stop vs. fixer TP vs. ST-Flip-Only.

Trailing Stop Logik (wie live):
  1. Entry mit SL (fix)
  2. Kein fixer TP
  3. Wenn PnL >= TRAIL_ACTIVATION_PCT: Trailing Stop aktivieren
  4. Trail Offset = TRAIL_ATR_MULT × ATR
  5. Exit wenn: SL hit, Trail hit, oder ST-Flip

Läuft auf Trading Station, DB via Tailscale.
"""

import psycopg2
import pandas as pd
import numpy as np
from itertools import product

