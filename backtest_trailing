SYMBOL = "SOLUSDT"

# Fixed params (aus vorherigem Scan bestätigt)
ST_ATR_PERIOD = 14
ST_MULTIPLIER = 2.0
AO_FAST = 7
AO_SLOW = 34
FEE_PCT = 0.055
FUNDING_LONG_MAX = 0.0001
FUNDING_SHORT_MIN = -0.0001


# ═══════════════════════════════════════════════════════════════════════
#  INDICATORS
# ═══════════════════════════════════════════════════════════════════════

def calc_atr(df, period=ST_ATR_PERIOD):
    tr = pd.concat([
        df["high"] - df["low"],
        (df["high"] - df["close"].shift(1)).abs(),
        (df["low"] - df["close"].shift(1)).abs()
    ], axis=1).max(axis=1)
    return tr.ewm(alpha=1.0 / period, min_periods=period, adjust=False).mean()


def calc_supertrend(df):
    df = df.copy()
    atr = calc_atr(df)
    df["atr"] = atr
    hl2 = (df["high"] + df["low"]) / 2.0
    upper = (hl2 + ST_MULTIPLIER * atr).values
    lower = (hl2 - ST_MULTIPLIER * atr).values
    close = df["close"].values
    n = len(df)

    fu = np.full(n, np.nan)
    fl = np.full(n, np.nan)
    d = np.zeros(n, dtype=int)
    s = ST_ATR_PERIOD

    if s >= n:
        df["st_direction"] = 0; df["st_long"] = False; df["st_short"] = False
        return df

    fu[s] = upper[s]; fl[s] = lower[s]; d[s] = -1
    for i in range(s + 1, n):
        fu[i] = upper[i] if (upper[i] < fu[i-1] or close[i-1] > fu[i-1]) else fu[i-1]
        fl[i] = lower[i] if (lower[i] > fl[i-1] or close[i-1] < fl[i-1]) else fl[i-1]
        if d[i-1] == 1:
            if close[i] < fl[i]: d[i] = -1
            else: d[i] = 1
        else:
            if close[i] > fu[i]: d[i] = 1
            else: d[i] = -1

    df["st_direction"] = d
    ds = pd.Series(d, index=df.index)
    df["st_long"] = (ds == 1) & (ds.shift(1) == -1)
    df["st_short"] = (ds == -1) & (ds.shift(1) == 1)
    return df


def calc_ao(df):
    df = df.copy()
    mid = (df["high"] + df["low"]) / 2.0
    df["ao"] = mid.rolling(AO_FAST).mean() - mid.rolling(AO_SLOW).mean()
    return df


# ═══════════════════════════════════════════════════════════════════════
#  BACKTEST ENGINE MIT TRAILING STOP
# ═══════════════════════════════════════════════════════════════════════

def backtest_trailing(df, sl_mult, trail_activation_pct, trail_atr_mult):
    """
    Trailing Stop Backtest.
    - Entry: Market bei ST-Flip + AO + FR
    - SL: sl_mult × ATR (fix)
    - Kein fixer TP
    - Bei PnL >= trail_activation_pct: Trailing Stop mit trail_atr_mult × ATR
    - Exit: SL, Trail, oder ST-Flip
    """
    trades = []
    pos = None

    for i in range(1, len(df)):
        row = df.iloc[i]
        c, h, l = row["close"], row["high"], row["low"]

        if pos:
            # Aktuellen PnL berechnen
            if pos["side"] == "long":
                current_pnl_pct = (c - pos["entry"]) / pos["entry"] * 100
            else:
                current_pnl_pct = (pos["entry"] - c) / pos["entry"] * 100

            # Trail aktivieren wenn noch nicht aktiv
            if not pos["trail_active"] and current_pnl_pct >= trail_activation_pct:
                trail_offset = row["atr"] * trail_atr_mult
                if pos["side"] == "long":
                    pos["trail_price"] = c - trail_offset
                else:
                    pos["trail_price"] = c + trail_offset
                pos["trail_active"] = True
                pos["trail_offset"] = trail_offset

            # Trail nachziehen (nur in Gewinnrichtung)
            if pos["trail_active"]:
                if pos["side"] == "long":
                    new_trail = h - pos["trail_offset"]
                    if new_trail > pos["trail_price"]:
                        pos["trail_price"] = new_trail
                else:
                    new_trail = l + pos["trail_offset"]
                    if new_trail < pos["trail_price"]:
                        pos["trail_price"] = new_trail

            # Exit checks
            exited = False

            if pos["side"] == "long":
                # SL check
                if l <= pos["sl"]:
                    pnl = (pos["sl"] - pos["entry"]) / pos["entry"] * 100
                    trades.append({"pnl": pnl, "exit": "SL", "bars": i - pos["bar"],
                                   "trail_was_active": pos["trail_active"]})
                    exited = True
                # Trail check
                elif pos["trail_active"] and l <= pos["trail_price"]:
                    pnl = (pos["trail_price"] - pos["entry"]) / pos["entry"] * 100
                    trades.append({"pnl": pnl, "exit": "TRAIL", "bars": i - pos["bar"],
                                   "trail_was_active": True})
                    exited = True
                # ST Flip
                elif row["st_short"]:
                    pnl = (c - pos["entry"]) / pos["entry"] * 100
                    trades.append({"pnl": pnl, "exit": "FLIP", "bars": i - pos["bar"],
                                   "trail_was_active": pos["trail_active"]})
                    exited = True
            else:
                if h >= pos["sl"]:
                    pnl = (pos["entry"] - pos["sl"]) / pos["entry"] * 100
                    trades.append({"pnl": pnl, "exit": "SL", "bars": i - pos["bar"],
                                   "trail_was_active": pos["trail_active"]})
                    exited = True
                elif pos["trail_active"] and h >= pos["trail_price"]:
                    pnl = (pos["entry"] - pos["trail_price"]) / pos["entry"] * 100
                    trades.append({"pnl": pnl, "exit": "TRAIL", "bars": i - pos["bar"],
                                   "trail_was_active": True})
                    exited = True
                elif row["st_long"]:
                    pnl = (pos["entry"] - c) / pos["entry"] * 100
                    trades.append({"pnl": pnl, "exit": "FLIP", "bars": i - pos["bar"],
                                   "trail_was_active": pos["trail_active"]})
                    exited = True

            if exited:
                pos = None
            else:
                continue

        if pos:
            continue

        # Signal
        sig = None
        if row["st_long"]: sig = "long"
        elif row["st_short"]: sig = "short"
        if not sig: continue

        # AO filter
        if sig == "long" and row["ao"] <= 0: continue
        if sig == "short" and row["ao"] >= 0: continue

        # FR filter
        fr = row.get("funding_rate", np.nan)
        if pd.notna(fr):
            if sig == "long" and fr > FUNDING_LONG_MAX: continue
            if sig == "short" and fr < FUNDING_SHORT_MIN: continue

        atr = row["atr"]
        if atr <= 0: continue

        if sig == "long":
            pos = {"side": "long", "entry": c, "sl": c - sl_mult * atr,
                   "bar": i, "trail_active": False, "trail_price": 0, "trail_offset": 0}
        else:
            pos = {"side": "short", "entry": c, "sl": c + sl_mult * atr,
                   "bar": i, "trail_active": False, "trail_price": 0, "trail_offset": 0}

    # Close open at end
    if pos:
        c = df.iloc[-1]["close"]
        if pos["side"] == "long":
            pnl = (c - pos["entry"]) / pos["entry"] * 100
        else:
            pnl = (pos["entry"] - c) / pos["entry"] * 100
        trades.append({"pnl": pnl, "exit": "END", "bars": len(df) - pos["bar"],
                       "trail_was_active": pos["trail_active"]})

    return analyze(trades)


def backtest_fixed_tp(df, sl_mult, tp_mult):
    """Fixer TP zum Vergleich."""
    trades = []
    pos = None

    for i in range(1, len(df)):
        row = df.iloc[i]
        c, h, l = row["close"], row["high"], row["low"]

        if pos:
            if pos["side"] == "long":
                if l <= pos["sl"]:
                    trades.append({"pnl": (pos["sl"]-pos["entry"])/pos["entry"]*100, "exit":"SL", "bars":i-pos["bar"], "trail_was_active":False})
                    pos = None
                elif h >= pos["tp"]:
                    trades.append({"pnl": (pos["tp"]-pos["entry"])/pos["entry"]*100, "exit":"TP", "bars":i-pos["bar"], "trail_was_active":False})
                    pos = None
                elif row["st_short"]:
                    trades.append({"pnl": (c-pos["entry"])/pos["entry"]*100, "exit":"FLIP", "bars":i-pos["bar"], "trail_was_active":False})
                    pos = None
            else:
                if h >= pos["sl"]:
                    trades.append({"pnl": (pos["entry"]-pos["sl"])/pos["entry"]*100, "exit":"SL", "bars":i-pos["bar"], "trail_was_active":False})
                    pos = None
                elif l <= pos["tp"]:
                    trades.append({"pnl": (pos["entry"]-pos["tp"])/pos["entry"]*100, "exit":"TP", "bars":i-pos["bar"], "trail_was_active":False})
                    pos = None
                elif row["st_long"]:
                    trades.append({"pnl": (pos["entry"]-c)/pos["entry"]*100, "exit":"FLIP", "bars":i-pos["bar"], "trail_was_active":False})
                    pos = None

        if pos: continue

        sig = None
        if row["st_long"]: sig = "long"
        elif row["st_short"]: sig = "short"
        if not sig: continue
        if sig == "long" and row["ao"] <= 0: continue
        if sig == "short" and row["ao"] >= 0: continue
        fr = row.get("funding_rate", np.nan)
        if pd.notna(fr):
            if sig == "long" and fr > FUNDING_LONG_MAX: continue
            if sig == "short" and fr < FUNDING_SHORT_MIN: continue
        atr = row["atr"]
        if atr <= 0: continue

        if sig == "long":
            pos = {"side":"long","entry":c,"sl":c-sl_mult*atr,"tp":c+tp_mult*atr,"bar":i}
        else:
            pos = {"side":"short","entry":c,"sl":c+sl_mult*atr,"tp":c-tp_mult*atr,"bar":i}

    return analyze(trades)


def backtest_flip_only(df, sl_mult):
    """Nur SL + ST-Flip, kein TP, kein Trail."""
    trades = []
    pos = None

    for i in range(1, len(df)):
        row = df.iloc[i]
        c, h, l = row["close"], row["high"], row["low"]

        if pos:
            if pos["side"] == "long":
                if l <= pos["sl"]:
                    trades.append({"pnl": (pos["sl"]-pos["entry"])/pos["entry"]*100, "exit":"SL", "bars":i-pos["bar"], "trail_was_active":False})
                    pos = None
                elif row["st_short"]:
                    trades.append({"pnl": (c-pos["entry"])/pos["entry"]*100, "exit":"FLIP", "bars":i-pos["bar"], "trail_was_active":False})
                    pos = None
            else:
                if h >= pos["sl"]:
                    trades.append({"pnl": (pos["entry"]-pos["sl"])/pos["entry"]*100, "exit":"SL", "bars":i-pos["bar"], "trail_was_active":False})
                    pos = None
                elif row["st_long"]:
                    trades.append({"pnl": (pos["entry"]-c)/pos["entry"]*100, "exit":"FLIP", "bars":i-pos["bar"], "trail_was_active":False})
                    pos = None

        if pos: continue
        sig = None
        if row["st_long"]: sig = "long"
        elif row["st_short"]: sig = "short"
        if not sig: continue
        if sig == "long" and row["ao"] <= 0: continue
        if sig == "short" and row["ao"] >= 0: continue
        fr = row.get("funding_rate", np.nan)
        if pd.notna(fr):
            if sig == "long" and fr > FUNDING_LONG_MAX: continue
            if sig == "short" and fr < FUNDING_SHORT_MIN: continue
        atr = row["atr"]
        if atr <= 0: continue

        if sig == "long":
            pos = {"side":"long","entry":c,"sl":c-sl_mult*atr,"bar":i}
        else:
            pos = {"side":"short","entry":c,"sl":c+sl_mult*atr,"bar":i}

    return analyze(trades)


def analyze(trades):
    if not trades:
        return None

    pnls = np.array([t["pnl"] - FEE_PCT * 2 for t in trades])
    bars = np.array([t["bars"] for t in trades])
    wins = (pnls > 0).sum()
    total = len(pnls)
    cum = np.cumsum(pnls)
    max_dd = (cum - np.maximum.accumulate(cum)).min()
    sharpe = pnls.mean() / pnls.std() * np.sqrt(total) if pnls.std() > 0 else 0
    gp = pnls[pnls > 0].sum()
    gl = abs(pnls[pnls <= 0].sum())
    pf = gp / gl if gl > 0 else float("inf")

    exits = {}
    trail_count = 0
    for t in trades:
        exits[t["exit"]] = exits.get(t["exit"], 0) + 1
        if t.get("trail_was_active"):
            trail_count += 1

    return {
        "trades": total, "wins": wins, "winrate": wins / total * 100,
        "total_pnl": pnls.sum(), "avg_pnl": pnls.mean(),
        "max_dd": max_dd, "sharpe": sharpe, "pf": pf,
        "avg_bars": bars.mean(), "exits": exits,
        "trail_activated": trail_count,
    }


