def test1_rsi_thresholds(df):
    print("\n" + "="*90)
    print("TEST 1: RSI THRESHOLD GRID")
    print("="*90)

    ob_values = [65, 70, 75, 80, 85]
    os_values = [15, 20, 25, 30, 35]

    results = []
    for ob, os_ in product(ob_values, os_values):
        r = backtest_rsi(df, rsi_ob=ob, rsi_os=os_)
        if r:
            r["ob"] = ob; r["os"] = os_
            results.append(r)

    results.sort(key=lambda x: x["sharpe"], reverse=True)

    print(f"\n{'OB':>4s} {'OS':>4s} | {'Trades':>6s} {'WR%':>5s} {'PnL%':>8s} {'Sharpe':>7s} "
          f"{'Sortino':>8s} {'PF':>6s} {'MaxDD':>7s} {'AvgPyr':>7s}")
    print("-"*75)
    for r in results[:20]:
        marker = " <-- LIVE" if r["ob"]==70 and r["os"]==30 else ""
        marker = " <-- ORIG" if r["ob"]==80 and r["os"]==20 else marker
        marker = " <-- BEST" if r == results[0] else marker
        print(f"{r['ob']:>4d} {r['os']:>4d} | {r['trades']:>6d} {r['winrate']:>4.0f}% "
              f"{r['total_pnl']:>+7.1f}% {r['sharpe']:>7.2f} {r['sortino']:>8.2f} "
              f"{r['pf']:>5.2f} {r['max_dd']:>6.1f}% {r['avg_pyramids']:>6.1f}{marker}")

    best = results[0]
    print(f"\n>>> Best RSI: OB={best['ob']} OS={best['os']} (Sharpe={best['sharpe']:.2f})")
    return best["ob"], best["os"]


