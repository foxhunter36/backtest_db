# ═══════════════════════════════════════════════════════════════════════
#  INDICATORS
# ═══════════════════════════════════════════════════════════════════════

def calc_rsi(df, length=RSI_LENGTH):
    delta = df["close"].diff()
    gain = delta.clip(lower=0)
    loss = (-delta).clip(lower=0)
    avg_gain = gain.ewm(alpha=1.0/length, min_periods=length, adjust=False).mean()
    avg_loss = loss.ewm(alpha=1.0/length, min_periods=length, adjust=False).mean()
    rs = avg_gain / avg_loss
    df = df.copy()
    df["rsi"] = 100 - (100 / (1 + rs))
    return df


# ═══════════════════════════════════════════════════════════════════════
#  BACKTEST ENGINE
# ═══════════════════════════════════════════════════════════════════════

def backtest_rsi(df, rsi_length=RSI_LENGTH, rsi_ob=RSI_OB, rsi_os=RSI_OS,
                 max_pyramids=MAX_PYRAMIDS, sl_pct=SL_PCT,
                 ts_act=TS_ACT, ts_trail=TS_TRAIL):
    """
    RSI Mean-Reversion Backtest mit Pyramiding.

    Logik (wie live):
    1. RSI < os → Long Entry (oder Pyramid wenn schon long)
    2. RSI > ob → Short Entry (oder Pyramid wenn schon short)
    3. SL wird erst nach max_pyramids aktiviert (sl_pct vom avg price)
    4. Trail: bei +ts_act% → Trailing Stop mit ts_trail% Offset
    5. Exit: SL, Trail, oder RSI-Gegenssignal
    """
    df = calc_rsi(df, rsi_length)
    df = df.dropna(subset=["rsi"]).reset_index(drop=True)

    trades = []
    pos = None  # {"side", "entries":[(price, qty)], "pyramid_count", "avg_price",
                #  "sl_active", "sl_price", "trail_active", "trail_price", "bar"}

    for i in range(1, len(df)):
        row = df.iloc[i]
        c, h, l = row["close"], row["high"], row["low"]
        rsi = row["rsi"]

        if pos:
            avg = pos["avg_price"]

            # ── PnL Check ──
            if pos["side"] == "long":
                pnl_pct = (c - avg) / avg * 100
            else:
                pnl_pct = (avg - c) / avg * 100

            # ── SL Activation (nach max_pyramids) ──
            if not pos["sl_active"] and pos["pyramid_count"] >= max_pyramids:
                if pos["side"] == "long":
                    pos["sl_price"] = avg * (1 - sl_pct / 100)
                else:
                    pos["sl_price"] = avg * (1 + sl_pct / 100)
                pos["sl_active"] = True

            # ── Trail Activation ──
            if not pos["trail_active"] and pnl_pct >= ts_act:
                trail_dist = c * ts_trail / 100
                if pos["side"] == "long":
                    pos["trail_price"] = c - trail_dist
                else:
                    pos["trail_price"] = c + trail_dist
                pos["trail_active"] = True
                pos["trail_dist"] = trail_dist

            # ── Trail Update ──
            if pos["trail_active"]:
                if pos["side"] == "long":
                    new_trail = h - pos["trail_dist"]
                    if new_trail > pos["trail_price"]:
                        pos["trail_price"] = new_trail
                else:
                    new_trail = l + pos["trail_dist"]
                    if new_trail < pos["trail_price"]:
                        pos["trail_price"] = new_trail

            # ── Exit Checks ──
            exited = False

            if pos["side"] == "long":
                if pos["sl_active"] and l <= pos["sl_price"]:
                    pnl = (pos["sl_price"] - avg) / avg * 100
                    trades.append({"pnl": pnl, "exit": "SL", "bars": i-pos["bar"],
                                   "pyramids": pos["pyramid_count"]})
                    exited = True
                elif pos["trail_active"] and l <= pos["trail_price"]:
                    pnl = (pos["trail_price"] - avg) / avg * 100
                    trades.append({"pnl": pnl, "exit": "TRAIL", "bars": i-pos["bar"],
                                   "pyramids": pos["pyramid_count"]})
                    exited = True
                elif rsi > rsi_ob:  # RSI Gegensignal
                    pnl = (c - avg) / avg * 100
                    trades.append({"pnl": pnl, "exit": "RSI_FLIP", "bars": i-pos["bar"],
                                   "pyramids": pos["pyramid_count"]})
                    exited = True
            else:
                if pos["sl_active"] and h >= pos["sl_price"]:
                    pnl = (avg - pos["sl_price"]) / avg * 100
                    trades.append({"pnl": pnl, "exit": "SL", "bars": i-pos["bar"],
                                   "pyramids": pos["pyramid_count"]})
                    exited = True
                elif pos["trail_active"] and h >= pos["trail_price"]:
                    pnl = (avg - pos["trail_price"]) / avg * 100
                    trades.append({"pnl": pnl, "exit": "TRAIL", "bars": i-pos["bar"],
                                   "pyramids": pos["pyramid_count"]})
                    exited = True
                elif rsi < rsi_os:  # RSI Gegensignal
                    pnl = (avg - c) / avg * 100
                    trades.append({"pnl": pnl, "exit": "RSI_FLIP", "bars": i-pos["bar"],
                                   "pyramids": pos["pyramid_count"]})
                    exited = True

            if exited:
                pos = None
            else:
                # ── Pyramiding ──
                if pos["pyramid_count"] < max_pyramids:
                    if pos["side"] == "long" and rsi < rsi_os:
                        pos["entries"].append(c)
                        pos["pyramid_count"] += 1
                        pos["avg_price"] = np.mean(pos["entries"])
                    elif pos["side"] == "short" and rsi > rsi_ob:
                        pos["entries"].append(c)
                        pos["pyramid_count"] += 1
                        pos["avg_price"] = np.mean(pos["entries"])
                continue

        # ── New Position ──
        if pos is not None:
            continue

        if rsi < rsi_os:
            pos = {"side": "long", "entries": [c], "pyramid_count": 1,
                   "avg_price": c, "sl_active": False, "sl_price": 0,
                   "trail_active": False, "trail_price": 0, "trail_dist": 0,
                   "bar": i}
        elif rsi > rsi_ob:
            pos = {"side": "short", "entries": [c], "pyramid_count": 1,
                   "avg_price": c, "sl_active": False, "sl_price": 0,
                   "trail_active": False, "trail_price": 0, "trail_dist": 0,
                   "bar": i}

    # Close open at end
    if pos:
        c = df.iloc[-1]["close"]
        avg = pos["avg_price"]
        if pos["side"] == "long":
            pnl = (c - avg) / avg * 100
        else:
            pnl = (avg - c) / avg * 100
        trades.append({"pnl": pnl, "exit": "END", "bars": len(df)-pos["bar"],
                       "pyramids": pos["pyramid_count"]})

    return analyze(trades)


def analyze(trades):
    if not trades: return None
    pnls = np.array([t["pnl"] - FEE_PCT*2 for t in trades])
    bars = np.array([t["bars"] for t in trades])
    pyramids = np.array([t["pyramids"] for t in trades])
    wins = (pnls > 0).sum(); total = len(pnls)
    cum = np.cumsum(pnls)
    max_dd = (cum - np.maximum.accumulate(cum)).min() if len(cum) > 0 else 0
    sharpe = pnls.mean() / pnls.std() * np.sqrt(total) if pnls.std() > 0 else 0

    gp = pnls[pnls > 0].sum(); gl = abs(pnls[pnls <= 0].sum())
    pf = gp / gl if gl > 0 else float("inf")

    down = pnls[pnls < 0]
    down_std = np.sqrt(np.mean(down**2)) if len(down) > 0 else 0
    sortino = pnls.mean() / down_std * np.sqrt(total) if down_std > 0 else 0

    days_approx = bars.sum() / (4 * 24)  # 15m bars → days
    ann_ret = pnls.sum() / (days_approx / 365) if days_approx > 0 else pnls.sum()
    calmar = ann_ret / abs(max_dd) if max_dd != 0 else 0

    exits = {}
    for t in trades: exits[t["exit"]] = exits.get(t["exit"], 0) + 1

    return {
        "trades": total, "wins": wins, "winrate": wins/total*100,
        "total_pnl": pnls.sum(), "avg_pnl": pnls.mean(), "max_dd": max_dd,
        "sharpe": sharpe, "sortino": sortino, "calmar": calmar,
        "pf": pf, "avg_bars": bars.mean(), "avg_pyramids": pyramids.mean(),
        "exits": exits,
    }


def fmt(r):
    if not r: return "(keine Trades)"
    ex = " ".join(f"{k}:{v}" for k,v in sorted(r["exits"].items()))
    return (f"Tr={r['trades']:>4d} WR={r['winrate']:>4.0f}% PnL={r['total_pnl']:>+7.1f}% "
            f"Sh={r['sharpe']:>5.2f} PF={r['pf']:>5.2f} DD={r['max_dd']:>6.1f}% "
            f"Pyr={r['avg_pyramids']:.1f} | {ex}")


